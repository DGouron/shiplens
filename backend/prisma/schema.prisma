generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model LinearWorkspaceConnection {
  id                    String   @id @default(uuid())
  workspaceId           String   @unique
  workspaceName         String
  encryptedAccessToken  String
  encryptedRefreshToken String
  grantedScopes         String
  status                String
  connectedAt           DateTime
  updatedAt             DateTime @updatedAt
}

model SelectedTeam {
  id       String @id @default(uuid())
  teamId   String @unique
  teamName String
}

model SelectedProject {
  id          String @id @default(uuid())
  projectId   String @unique
  projectName String
  teamId      String
}

model Label {
  id         String @id @default(uuid())
  externalId String
  teamId     String
  name       String
  color      String

  @@unique([externalId, teamId])
}

model WorkflowStatus {
  id         String @id @default(uuid())
  externalId String
  teamId     String
  name       String
  position   Int

  @@unique([externalId, teamId])
}

model TeamMember {
  id         String @id @default(uuid())
  externalId String
  teamId     String
  name       String
  role       String

  @@unique([externalId, teamId])
}

model Project {
  id         String      @id @default(uuid())
  externalId String
  teamId     String
  name       String
  milestones Milestone[]

  @@unique([externalId, teamId])
}

model Milestone {
  id                String  @id @default(uuid())
  externalId        String
  projectExternalId String
  name              String
  project           Project @relation(fields: [projectExternalId, projectTeamId], references: [externalId, teamId])
  projectTeamId     String

  @@unique([externalId, projectExternalId])
}

model Issue {
  id                String  @id @default(uuid())
  externalId        String
  teamId            String
  title             String
  statusName        String
  statusType        String  @default("unstarted")
  points            Int?
  labelIds          String
  assigneeName      String?
  projectExternalId String?
  createdAt         String
  updatedAt         String
  deletedAt         String?

  @@unique([externalId, teamId])
}

model Cycle {
  id               String @id @default(uuid())
  externalId       String
  teamId           String
  name             String?
  number           Int?
  startsAt         String
  endsAt           String
  issueExternalIds String

  @@unique([externalId, teamId])
}

model StateTransition {
  id              String  @id @default(uuid())
  externalId      String
  issueExternalId String
  teamId          String
  fromStatusName  String?
  fromStatusType  String?
  toStatusName    String
  toStatusType    String  @default("unstarted")
  occurredAt      String

  @@unique([externalId, teamId])
}

model WebhookEvent {
  id           String  @id @default(uuid())
  deliveryId   String  @unique
  action       String
  type         String
  teamId       String
  status       String
  attempts     Int     @default(0)
  receivedAt   String
  processedAt  String?
  errorMessage String?
}

model Comment {
  id              String @id @default(uuid())
  externalId      String
  issueExternalId String
  teamId          String
  body            String
  authorName      String
  createdAt       String

  @@unique([externalId, teamId])
}

model SyncProgress {
  id           String   @id @default(uuid())
  teamId       String   @unique
  totalIssues  Int
  syncedIssues Int
  status       String
  cursor       String?
  updatedAt    DateTime @updatedAt
}

model SprintReport {
  id               String  @id @default(uuid())
  cycleId          String
  teamId           String
  cycleName        String
  language         String
  generatedAt      String
  executiveSummary String
  trends           String?
  highlights       String
  risks            String
  recommendations  String
  auditSection     String?
}

model StatusThreshold {
  id             String @id @default(uuid())
  statusName     String @unique
  thresholdHours Int
}

model BlockedIssueAlert {
  id              String  @id @default(uuid())
  issueExternalId String
  issueTitle      String
  issueUuid       String
  teamId          String  @default("")
  statusName      String
  severity        String
  durationHours   Int
  detectedAt      String
  active          Boolean
  resolvedAt      String?
}

model SlackNotificationConfig {
  id         String  @id @default(uuid())
  teamId     String  @unique
  webhookUrl String
  enabled    Boolean
}

model TeamAlertChannel {
  id         String @id @default(uuid())
  teamId     String @unique
  webhookUrl String
}

model SlackAlertLog {
  id              String @id @default(uuid())
  issueExternalId String
  sentAt          String
}

model TeamWorkflowConfig {
  id                String @id @default(uuid())
  teamId            String @unique
  startedStatuses   String
  completedStatuses String
  source            String
}
