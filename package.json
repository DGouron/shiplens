{
  "name": "shiplens",
  "version": "0.0.1",
  "description": "Turn Linear project data into actionable insights",
  "author": "Damien Gouron",
  "private": true,
  "license": "MIT",
  "scripts": {
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "lint:ci": "pnpm -r lint:ci",
    "typecheck": "pnpm -r typecheck",
    "format": "pnpm -r format",
    "backend:dev": "pnpm --filter @shiplens/backend start:dev",
    "backend:start": "pnpm --filter @shiplens/backend start",
    "backend:start:prod": "pnpm --filter @shiplens/backend start:prod",
    "backend:test:e2e": "pnpm --filter @shiplens/backend test:e2e",
    "backend:prisma:generate": "pnpm --filter @shiplens/backend prisma:generate",
    "backend:prisma:studio": "pnpm --filter @shiplens/backend prisma:studio",
    "db:backup": "bash scripts/backup-database.sh",
    "db:migrate": "pnpm --filter @shiplens/backend db:migrate",
    "db:deploy": "pnpm --filter @shiplens/backend db:deploy",
    "db:status": "pnpm --filter @shiplens/backend db:status",
    "frontend:dev": "pnpm --filter @shiplens/frontend dev",
    "frontend:build": "pnpm --filter @shiplens/frontend build",
    "frontend:preview": "pnpm --filter @shiplens/frontend preview",
    "postinstall": "pnpm --filter @shiplens/backend prisma:generate",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/node": "^22.10.7",
    "lefthook": "^2.1.4",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/engines",
      "prisma",
      "unrs-resolver",
      "@swc/core",
      "better-sqlite3",
      "lefthook"
    ]
  },
  "packageManager": "pnpm@10.29.3+sha512.498e1fb4cca5aa06c1dcf2611e6fafc50972ffe7189998c409e90de74566444298ffe43e6cd2acdc775ba1aa7cc5e092a8b7054c811ba8c5770f84693d33d2dc"
}
