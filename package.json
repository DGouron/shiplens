{
  "name": "shiplens",
  "version": "0.0.1",
  "description": "Turn Linear project data into actionable insights",
  "author": "Damien Gouron",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "biome format --write src/ tests/",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main/main",
    "lint": "biome check --write src/ tests/",
    "lint:ci": "biome ci src/ tests/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "playwright test",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "db:migrate": "bash scripts/backup-database.sh && prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:status": "prisma migrate status",
    "db:backup": "bash scripts/backup-database.sh",
    "postinstall": "prisma generate",
    "prepare": "lefthook install",
    "frontend:dev": "pnpm --filter @shiplens/frontend dev",
    "frontend:build": "pnpm --filter @shiplens/frontend build",
    "frontend:test": "pnpm --filter @shiplens/frontend test",
    "frontend:lint:ci": "pnpm --filter @shiplens/frontend lint:ci",
    "frontend:typecheck": "pnpm --filter @shiplens/frontend typecheck"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/serve-static": "^5.0.5",
    "@prisma/adapter-better-sqlite3": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@playwright/test": "^1.58.2",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.21",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.2",
    "lefthook": "^2.1.4",
    "prisma": "^7.6.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/engines",
      "prisma",
      "unrs-resolver",
      "@swc/core",
      "better-sqlite3",
      "lefthook"
    ]
  },
  "packageManager": "pnpm@10.29.3+sha512.498e1fb4cca5aa06c1dcf2611e6fafc50972ffe7189998c409e90de74566444298ffe43e6cd2acdc775ba1aa7cc5e092a8b7054c811ba8c5770f84693d33d2dc"
}
