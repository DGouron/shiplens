generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model LinearWorkspaceConnection {
  id                    String   @id @default(uuid())
  workspaceId           String   @unique
  workspaceName         String
  encryptedAccessToken  String
  encryptedRefreshToken String
  grantedScopes         String
  status                String
  connectedAt           DateTime
  updatedAt             DateTime @updatedAt
}

model SelectedTeam {
  id       String @id @default(uuid())
  teamId   String @unique
  teamName String
}

model SelectedProject {
  id          String @id @default(uuid())
  projectId   String @unique
  projectName String
  teamId      String
}

model Label {
  id         String @id @default(uuid())
  externalId String
  teamId     String
  name       String
  color      String

  @@unique([externalId, teamId])
}

model WorkflowStatus {
  id         String @id @default(uuid())
  externalId String
  teamId     String
  name       String
  position   Int

  @@unique([externalId, teamId])
}

model TeamMember {
  id         String @id @default(uuid())
  externalId String
  teamId     String
  name       String
  role       String

  @@unique([externalId, teamId])
}

model Project {
  id         String      @id @default(uuid())
  externalId String
  teamId     String
  name       String
  milestones Milestone[]

  @@unique([externalId, teamId])
}

model Milestone {
  id                String  @id @default(uuid())
  externalId        String
  projectExternalId String
  name              String
  project           Project @relation(fields: [projectExternalId, projectTeamId], references: [externalId, teamId])
  projectTeamId     String

  @@unique([externalId, projectExternalId])
}

model Issue {
  id           String  @id @default(uuid())
  externalId   String
  teamId       String
  title        String
  statusName   String
  points       Int?
  labelIds     String
  assigneeName String?
  createdAt    String
  updatedAt    String

  @@unique([externalId, teamId])
}

model Cycle {
  id               String @id @default(uuid())
  externalId       String
  teamId           String
  name             String?
  startsAt         String
  endsAt           String
  issueExternalIds String

  @@unique([externalId, teamId])
}

model StateTransition {
  id              String  @id @default(uuid())
  externalId      String
  issueExternalId String
  teamId          String
  fromStatusName  String?
  toStatusName    String
  occurredAt      String

  @@unique([externalId, teamId])
}

model SyncProgress {
  id           String  @id @default(uuid())
  teamId       String  @unique
  totalIssues  Int
  syncedIssues Int
  status       String
  cursor       String?
}
